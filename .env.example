# =============================================================
# PLATAFORMA DIGITAL — LIRIO DE LOS VALLES
# Copiar a .env y completar con valores reales
# NUNCA commitear .env con valores reales
# =============================================================

# PostgreSQL
POSTGRES_DB=lirio_db
POSTGRES_USER=lirio_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_20_CHARS

# Directus
DIRECTUS_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE
DIRECTUS_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE
DIRECTUS_ADMIN_EMAIL=admin@liriodelosvallescr.org
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DIRECTUS_PUBLIC_URL=https://admin.liriodelosvallescr.org

# NextAuth v5 (Auth.js) — Portal de Asociados
# Generar: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret
# Redirect URI en Google Cloud Console: https://liriodelosvallescr.org/api/auth/callback/google
NEXTAUTH_URL=https://liriodelosvallescr.org

# Directus tokens — NUNCA usar DIRECTUS_ADMIN_TOKEN en APIs web expuestas
# Admin token: Directus → Settings → Access Tokens → "Next.js Admin"
# Uso: solo scripts, migrations, CLI, syncGoogleUser en auth.ts (server-side, nunca público)
DIRECTUS_ADMIN_TOKEN=CHANGE_ME_DIRECTUS_ADMIN_TOKEN
# Documents token (scoped): Directus → Settings → Access Tokens → "Documents Service"
# Permisos: read asociados_documents + read directus_files (solo esos campos)
DIRECTUS_DOCUMENTS_TOKEN=CHANGE_ME_DIRECTUS_DOCUMENTS_TOKEN

# Google OAuth (legacy — mantener para compatibilidad)
# Usar AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET para NextAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# YouTube Data API v3
# Crear en: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# Next.js — URLs públicas
NEXT_PUBLIC_DIRECTUS_URL=https://api.liriodelosvallescr.org
NEXT_PUBLIC_SITE_URL=https://liriodelosvallescr.org

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Umami Analytics (perfil opcional — docker compose --profile analytics up)
UMAMI_DATABASE_URL=postgresql://lirio_user:CHANGE_ME@postgres:5432/umami_db
UMAMI_APP_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE

# Azure Blob Storage (para backups)
AZURE_STORAGE_ACCOUNT=liriostorageacct
AZURE_STORAGE_KEY=your_azure_storage_key
AZURE_BACKUP_CONTAINER=backups

# Sync job — GitHub Actions usa este token para disparar /api/sync/youtube
SYNC_SECRET=<openssl rand -base64 32>
TEAM_SECRET=<openssl rand -hex 32>
